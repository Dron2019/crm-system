# Vite dev server proxy target for backend API.
# Used only by `npm run dev` in vite.config.ts.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# API base URL used by axios client in src/lib/api.ts.
# Keep as relative path for same-origin deployments.
VITE_API_BASE_URL=/api/v1

# CSRF cookie endpoint used before login/register.
# Keep as relative path for same-origin deployments.
VITE_CSRF_COOKIE_URL=/sanctum/csrf-cookie
