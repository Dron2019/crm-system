{
    "name": "crm-system",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n api,spa -c cyan,magenta \"php artisan serve --host=127.0.0.1 --port=8000\" \"vite --config vite.config.ts\"",
        "dev:api": "php artisan serve --host=127.0.0.1 --port=8000",
        "dev:spa": "vite --config vite.config.ts",
        "build": "tsc -b && vite build --config vite.config.ts",
        "preview": "vite preview --config vite.config.ts",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@emotion/react": "^11.13.0",
        "@emotion/styled": "^11.13.0",
        "@hookform/resolvers": "^3.9.0",
        "@mui/icons-material": "^6.1.0",
        "@mui/material": "^6.1.0",
        "@tanstack/react-query": "^5.56.0",
        "@tanstack/react-query-devtools": "^5.56.0",
        "axios": "^1.11.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.53.0",
        "react-router-dom": "^6.26.0",
        "zod": "^3.23.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.9.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "concurrently": "^9.0.1",
        "eslint": "^9.9.0",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.9",
        "globals": "^15.9.0",
        "jsdom": "^24.1.3",
        "typescript": "~5.6.0",
        "typescript-eslint": "^8.0.1",
        "vite": "^5.4.0",
        "vitest": "^2.1.9"
    }
}
